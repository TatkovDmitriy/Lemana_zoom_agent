rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(resource) {
      return resource.data.ownerId == request.auth.uid;
    }
    function isNewOwner() {
      return request.resource.data.ownerId == request.auth.uid;
    }

    // ── Users ─────────────────────────────────────────────────────
    match /users/{uid} {
      allow read, write: if isAuth() && request.auth.uid == uid;
    }

    // ── Projects ──────────────────────────────────────────────────
    match /projects/{projectId} {
      allow read: if isAuth() && isOwner(resource);
      allow create: if isAuth() && isNewOwner();
      allow update, delete: if isAuth() && isOwner(resource);
    }

    // ── Minutes ───────────────────────────────────────────────────
    match /minutes/{minuteId} {
      allow read: if isAuth() && isOwner(resource);
      allow create: if isAuth() && isNewOwner();
      allow update, delete: if isAuth() && isOwner(resource);
    }

    // ── Jobs ──────────────────────────────────────────────────────
    // Client can subscribe (read) to its own jobs to render the bot status
    // panel on /join. All writes still go through the Admin SDK (the bot,
    // the watcher, and /api/bot/* routes) so client-side write is denied.
    match /jobs/{jobId} {
      allow read: if isAuth() && resource.data.payload.ownerId == request.auth.uid;
      allow write: if false;
    }
    match /zoom_tokens/{docId} {
      allow read, write: if false;
    }
    match /telegram_bindings/{code} {
      allow read, write: if false;
    }
  }
}
