# ============================================================
# Lemana Zoom Agent — Environment Variables
# Copy to .env.local, fill in values, NEVER commit .env.local
# ============================================================

# --- GitHub (Obsidian commits) ---
GITHUB_TOKEN=                          # PAT, scope: repo
GITHUB_OBSIDIAN_REPO=TatkovDmitriy/Obsidian
GITHUB_OBSIDIAN_BRANCH=main

# --- Firebase Admin SDK (backend, server-side only) ---
FIREBASE_PROJECT_ID=impact-calc-lp
FIREBASE_ADMIN_CLIENT_EMAIL=           # service account email
FIREBASE_ADMIN_PRIVATE_KEY=            # keep \n literals — code does replace(/\\n/g, '\n')

# --- Firebase Web SDK (frontend, public values) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=impact-calc-lp
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5      # configurable model id

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=LemanaZoomBot
TELEGRAM_ALLOWED_USER_IDS=            # comma-separated Telegram user IDs

# --- Zoom (MCP + webhook) ---
ZOOM_MCP_SERVER_URL=
ZOOM_ACCOUNT_EMAIL=                   # corporate SSO email
ZOOM_WEBHOOK_SECRET_TOKEN=            # from Zoom app → Feature → Event Subscriptions

# --- Encryption (AES-256-GCM for Zoom refresh tokens in Firestore) ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# --- Web App ---
NEXTAUTH_URL=                         # https://<your-vercel-domain>
WEB_APP_BASE_URL=                     # same URL, used for deep links from Telegram

# --- Railway (watcher + bot) ---
# Set these in Railway project settings, not here
# PORT is injected by Railway automatically
