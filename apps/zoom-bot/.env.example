# Firebase Admin (same project as web/watcher)
FIREBASE_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# OpenAI Whisper for audio transcription
OPENAI_API_KEY=

# Zoom Meeting SDK credentials (separate from Server-to-Server OAuth)
# https://marketplace.zoom.us → Build App → Meeting SDK
ZOOM_SDK_KEY=
ZOOM_SDK_SECRET=

# Bot identity shown to other meeting participants
ZOOM_BOT_NAME=Lemana AI

# BOT_MODE=mock  → simulate a 30s meeting with placeholder transcript
# BOT_MODE=real  → use the Zoom Linux Meeting SDK binary (see README)
BOT_MODE=mock

# Optional: path to the Zoom SDK binary inside the container
ZOOM_SDK_BINARY=/app/zoom-sdk/zoommtg

# HTTP port (Railway healthcheck)
PORT=4001
